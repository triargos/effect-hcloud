{
  "name": "effect-hcloud-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Generator + dual-target (Effect v3/v4) SDK for the Hetzner Cloud API, published as @triargos/effect-hcloud",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "fetch-spec": "node spec/fetch.ts",
    "generate": "node generator/src/generate.ts",
    "typecheck": "pnpm run typecheck:v3 && pnpm run typecheck:v4",
    "typecheck:v3": "pnpm -C packages/v3 run typecheck",
    "typecheck:v4": "pnpm -C packages/v4 run typecheck",
    "build": "pnpm run build:v3 && pnpm run build:v4",
    "build:v3": "pnpm -C packages/v3 run build",
    "build:v4": "pnpm -C packages/v4 run build",
    "regen": "pnpm run fetch-spec && pnpm run generate && pnpm run typecheck",
    "bootstrap": "pnpm install && pnpm run install:v4",
    "install:v4": "pnpm -C packages/v4 install --ignore-workspace",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:v3": "changeset publish",
    "publish:v4": "node scripts/set-v4-version.mjs && npm publish ./packages/v4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.9.3"
  }
}
